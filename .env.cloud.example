# Temporal Cloud Configuration
# Copy this file to .env.cloud and fill in your values
#
# To use: just up-cloud
#
# Get your namespace from: https://cloud.temporal.io/namespaces

# Your Temporal Cloud address (required)
# Format: <namespace>.<accountId>.tmprl.cloud:7233
TEMPORAL_ADDRESS=your-namespace.your-account.tmprl.cloud:7233

# Your namespace name (required)
# Format: <namespace>.<accountId>
TEMPORAL_NAMESPACE=your-namespace.your-account

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION - Choose ONE method (mTLS recommended for demos)
# ═══════════════════════════════════════════════════════════════════════════════

# Option 1: mTLS (recommended)
# Generate certificates at: https://cloud.temporal.io/namespaces/<namespace>/certificates
# Place your .pem and .key files in the ./certs directory
TEMPORAL_CERT_PATH=/certs/client.pem
TEMPORAL_KEY_PATH=/certs/client.key

# Option 2: API Key (uncomment and set, remove cert paths above)
# Create API keys at: https://cloud.temporal.io/settings/api-keys
# TEMPORAL_API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════════════════════════════

# Enable payload encryption (optional)
# ENCRYPT_PAYLOADS=true
